#!/usr/bin/env python3
"""
SCons build file for atlas georeferencing workflow.

Converting raw tiff scans to smaller jpgs and generating pdf.

Watches tie point files and regenerates georeferenced maps when they change.

Tobias Staal 2025
"""
import os
import re
from pathlib import Path
from datetime import datetime

import numpy as np
import pandas as pd
import geopandas as gpd
import rasterio
from rasterio.control import GroundControlPoint
from rasterio.transform import from_gcps
import pyproj
from pyproj import CRS
import csv

from SCons.Script import Action, Builder

# ============================================================================
# SINGLE ENVIRONMENT DEFINITION
# ============================================================================

env = Environment(ENV=os.environ.copy())

atlas_master = 'atlas_master.xlsx'

# Export directory
export_dir = 'export'

# Directory paths
jpg_large_dir = f'{export_dir}/jpg_large/atlas_antarktiki_I'
jpg_small_dir = f'{export_dir}/jpg_small/atlas_antarktiki_I'
pdf_bw_I_dir = f'{export_dir}/pdf_bw/atlas_antarktiki_I'
pdf_bw_II_dir = f'{export_dir}/pdf_bw/atlas_antarktiki_II'

for d in [jpg_large_dir, jpg_small_dir, pdf_bw_I_dir, pdf_bw_II_dir]:
    os.makedirs(d, exist_ok=True)


# ============================================================================
# IMAGE CONVERSION AND PDF GENERATION
# ============================================================================

def create_magick_action(command):
    """Create Action with stable command string for MD5 calculation."""
    return Action(command, cmdstr=command.replace('$', '$$'))


# Build images and PDFs for Volume I
pdf_I_nodes = {}
for tiff in Glob('LZW compression TIFF/Atlas Antarktiki I/*.tif'):
    base_name = os.path.splitext(os.path.basename(str(tiff)))[0]

    # Large JPG
    large_jpg = f'{jpg_large_dir}/{base_name}.jpg'
    env.Command(
        target=large_jpg,
        source=tiff,
        action=create_magick_action(
            'magick $SOURCE -define registry:warning=none -compress JPEG '
            '-quality 90% -level 2%,98% $TARGET'
        )
    )

    # Small JPG
    small_jpg = f'{jpg_small_dir}/{base_name}.jpg'
    env.Command(
        target=small_jpg,
        source=tiff,
        action=create_magick_action(
            'magick $SOURCE -define registry:warning=none -resize 50% -compress JPEG '
            '-quality 55% -level 4%,96% $TARGET'
        )
    )

    # PDF for OCR
    pdf = f'{pdf_bw_I_dir}/{base_name}.pdf'
    node = env.Command(
        target=pdf,
        source=tiff,
        action=create_magick_action(
            'magick $SOURCE -define registry:warning=none -density 400 -colorspace gray '
            '-normalize -level 4%,96% -background white -flatten -morphology Close Diamond:1 '
            '-sharpen 0x1.0 -deskew 40% -quality 75 -compress jpeg $TARGET'
        )
    )
    pdf_I_nodes[base_name] = node[0]

# Build OCR PDFs for Volume II
pdf_II_nodes = {}
for tiff in Glob('LZW compression TIFF/Atlas Antarktiki II/*.tif'):
    base_name = os.path.splitext(os.path.basename(str(tiff)))[0]
    pdf = f'{pdf_bw_II_dir}/{base_name}.pdf'
    node = env.Command(
        target=pdf,
        source=tiff,
        action=create_magick_action(
            'magick $SOURCE -define registry:warning=none -density 300 -colorspace gray '
            '-level 4%,96% -background white -flatten -morphology Close Diamond:1 '
            '-sharpen 0x1.0 -deskew 40% -quality 75 -compress jpeg $TARGET'
        )
    )
    pdf_II_nodes[base_name] = node[0]


# ============================================================================
# PDF COMPILATION ORDERING
# ============================================================================

def get_ordered_nodes(csv_filename, node_dict):
    """Read CSV to determine page ordering for compiled PDF."""
    ordered = []
    with open(csv_filename, newline='', encoding='utf-8') as csvfile:
        reader = csv.DictReader(csvfile)
        rows = []
        for row in reader:
            raw_path = row.get('Raw path', '').strip()
            compile_order = row.get('Compile order', '').strip()
            if raw_path and compile_order.isdigit():
                base = os.path.splitext(os.path.basename(raw_path))[0]
                if base in node_dict:
                    rows.append((int(compile_order), node_dict[base]))
        rows.sort()
        ordered = [node for _, node in rows]
    return ordered


volume_I_csv_file = 'volume_I.csv'
volume_II_csv_file = 'volume_II.csv'

volume_I_ordered_nodes = get_ordered_nodes(volume_I_csv_file, pdf_I_nodes)
volume_II_ordered_nodes = get_ordered_nodes(volume_II_csv_file, pdf_II_nodes)

# Compile complete PDF for Volume I (with CSV as dependency)
vol_I_pdf = env.Command(
    target=f'{export_dir}/atlas_antarktiki_I_complete.pdf',
    source=volume_I_ordered_nodes,
    action='gs -sDEVICE=pdfwrite -dNOPAUSE -dBATCH -dSAFER '
           '-sOutputFile="$TARGET" -dAutoRotatePages=/None '
           '-dPDFSETTINGS=/ebook -dCompatibilityLevel=1.4 $SOURCES'
)
env.Depends(vol_I_pdf, volume_I_csv_file)

# Compile complete PDF for Volume II (with CSV as dependency)
vol_II_pdf = env.Command(
    target=f'{export_dir}/atlas_antarktiki_II_complete.pdf',
    source=volume_II_ordered_nodes,
    action='gs -sDEVICE=pdfwrite -dNOPAUSE -dBATCH -dSAFER '
           '-sOutputFile="$TARGET" -dAutoRotatePages=/None '
           '-dPDFSETTINGS=/ebook -dCompatibilityLevel=1.4 $SOURCES'
)
env.Depends(vol_II_pdf, volume_II_csv_file)


# ============================================================================
# HELPER FUNCTIONS
# ============================================================================

def get_target_crs(crs_value, default_crs=3031):
    """
    Extract and validate EPSG code from Excel cell.
    Returns integer EPSG code or default.
    """
    if pd.isna(crs_value):
        return default_crs

    crs_str = str(crs_value).strip()

    if crs_str in ('', '-', 'NA', 'N/A', 'None', 'nan'):
        return default_crs

    try:
        return int(crs_str)
    except ValueError:
        return default_crs


def sanitise_key(text):
    """
    Convert a string into a safe BibTeX citation key fragment.
    Keeps ASCII alphanumerics and underscores, collapses whitespace to '_'.
    """
    text = re.sub(r'[^\w\s]', '', str(text))
    text = re.sub(r'\s+', '_', text.strip())
    return text.lower()


def safe_field(value):
    """Return field value as a cleaned string, or empty string if NaN/missing."""
    if pd.isna(value):
        return ''
    return str(value).strip()


def escape_bibtex(text):
    """Escape special BibTeX characters."""
    text = text.replace('&', r'\&')
    text = text.replace('%', r'\%')
    text = text.replace('#', r'\#')
    text = text.replace('_', r'\_')
    return text


# ============================================================================
# BIBTEX GENERATION FOR INDIVIDUAL MAP PLATES
# ============================================================================

def is_map_scale(scale_str):
    """
    Return True if scale_str looks like a cartographic ratio (e.g. '1:80,000,000').
    Returns False for content-type words like 'photo', 'diagram', 'table'.
    """
    import re as _re
    return bool(_re.match(r'^\s*1\s*:\s*[\d,\.\s]+$', scale_str))


def generate_bibtex_entry(row, volume=1):
    """
    Generate a BibTeX @incollection entry for any row in the atlas spreadsheet.

    Scale field interpretation:
        - Ratio string (e.g. '1:80,000,000') → type = {map}, note = {Scale ...}
        - Word  (e.g. 'photo', 'diagram')    → type = {photo} / {diagram} etc.
        - Empty / NaN                         → type field omitted

    Fields populated from spreadsheet columns:
        Part, Section, Subsection, Plate, Map Index, Map Subindex,
        Title, Sub title, Scale, Author, Editor
    """

    plate = safe_field(row.get('Plate', ''))
    map_idx = safe_field(row.get('Map Index', ''))
    map_subidx = safe_field(row.get('Map Subindex', ''))
    title = safe_field(row.get('Title', ''))

    plate_str = plate.replace(' ', '').zfill(3) if plate else '000'
    idx_str = f"_{map_idx}" if map_idx else ''
    subidx_str = map_subidx if map_subidx else ''
    title_fragment = sanitise_key(title)[:30] if title else 'untitled'

    cite_key = f"atlas_{('I' if volume == 1 else 'II')}_{plate_str}{idx_str}{subidx_str}_{title_fragment}"

    # Title: combine Title and Sub title
    entry_title = escape_bibtex(title) if title else 'Untitled'
    subtitle = safe_field(row.get('Sub title', ''))
    if subtitle:
        entry_title += f": {escape_bibtex(subtitle)}"

    author = safe_field(row.get('Author', ''))
    editor = safe_field(row.get('Editor', ''))
    scale = safe_field(row.get('Scale', ''))

    # Determine content type from Scale field
    if scale and is_map_scale(scale):
        content_type = 'map'
        scale_note = f"Scale {escape_bibtex(scale)}"
    elif scale:
        content_type = scale.lower().strip()
        scale_note = ''
    else:
        content_type = ''
        scale_note = ''

    part = safe_field(row.get('Part', ''))
    section = safe_field(row.get('Section', ''))
    subsection = safe_field(row.get('Subsection', ''))

    location_parts = []
    if part:
        location_parts.append(f"Part {escape_bibtex(part)}")
    if section:
        location_parts.append(f"Section {escape_bibtex(section)}")
    if subsection:
        location_parts.append(f"Subsection {escape_bibtex(subsection)}")

    plate_ref = ''
    if plate:
        plate_ref = f"Plate {plate}"
        if map_idx:
            plate_ref += f", Map {map_idx}"
        if map_subidx:
            plate_ref += f"{map_subidx}"

    lines = []
    lines.append(f"@incollection{{{cite_key},")

    if author:
        lines.append(f"  author       = {{{escape_bibtex(author)}}},")

    lines.append(f"  title        = {{{entry_title}}},")
    lines.append(f"  booktitle    = {{Atlas Antarktiki}},")

    if editor:
        lines.append(f"  editor       = {{{escape_bibtex(editor)}}},")

    lines.append(f"  volume       = {{{volume}}},")
    lines.append(f"  publisher    = {{Glavnoye upravleniye geodezii i kartografii pri Sovete Ministrov SSSR}},")
    lines.append(f"  address      = {{Moscow}},")
    lines.append(f"  year         = {{1966}},")

    if content_type:
        lines.append(f"  type         = {{{content_type}}},")

    if scale_note:
        lines.append(f"  note         = {{{scale_note}}},")
    elif location_parts:
        lines.append(f"  note         = {{{'; '.join(location_parts)}}},")

    if scale_note and location_parts:
        lines.append(f"  annote       = {{{'; '.join(location_parts)}}},")

    if plate_ref:
        lines.append(f"  pages        = {{{plate_ref}}},")

    lines.append(f"  crossref     = {{tolstikov1966}}")
    lines.append(f"}}")

    return cite_key, '\n'.join(lines)


# Keep old name as alias for backward compatibility within this file
generate_map_bibtex = generate_bibtex_entry


ATLAS_PARENT_BIB = """@book{tolstikov1966,
  author    = {Tolstikov, Evgenii Ivanovich},
  title     = {Atlas Antarktiki},
  volume    = {1},
  year      = {1966},
  publisher = {Glavnoye upravleniye geodezii i kartografii pri Sovete Ministrov SSSR},
  address   = {Moscow}
}
"""


def write_bibtex_file(bib_path, bib_entry):
    """
    Write a .bib file containing the atlas parent entry and the map entry.
    """
    content = (
        f"% Auto-generated by SConstruct — {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n"
        f"% Map-level citation for: {Path(bib_path).stem}\n\n"
        f"{ATLAS_PARENT_BIB}\n"
        f"{bib_entry}\n"
    )
    with open(bib_path, 'w', encoding='utf-8') as f:
        f.write(content)


def bibtex_builder(target, source, env):
    """
    SCons builder that generates a .bib file for a map plate.

    target[0]: .bib file (output)
    source[0]: atlas_master.xlsx (input dependency)
    env: must contain BIB_ENTRY (the pre-rendered BibTeX string)
    """
    bib_path = str(target[0])
    bib_entry = env.get('BIB_ENTRY', '')

    try:
        write_bibtex_file(bib_path, bib_entry)
        print(f"OK: Generated {bib_path}")
        return 0
    except Exception as e:
        print(f"ERROR: Writing {bib_path}: {e}")
        return 1


bibtex_action = Action(bibtex_builder, "Generating BibTeX $TARGET")
bibtex_builder_obj = Builder(action=bibtex_action)
env.Append(BUILDERS={'BibTeX': bibtex_builder_obj})


# ============================================================================
# GEOREFERENCING FUNCTION
# ============================================================================

def georeference_map(source_raster, target_raster, tie_points, log_file, target_crs=3031):
    """
    Re-georeferences from point vector using affine (1st-order polynomial) fit.
    Generates a detailed log file with transformation statistics.
    Returns the path to the log file.
    """

    log_lines = []
    log_lines.append("=" * 80)
    log_lines.append("GEOREFERENCING REPORT")
    log_lines.append("=" * 80)
    log_lines.append(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    log_lines.append(f"Source Raster: {source_raster}")
    log_lines.append(f"Target Raster: {target_raster}")
    log_lines.append(f"Tie Points: {tie_points}")
    log_lines.append("")

    custom_crs = CRS.from_epsg(target_crs)
    log_lines.append(f"Target CRS: {custom_crs}")
    print(f"Using CRS: {custom_crs}")

    gdf = gpd.read_file(tie_points)
    log_lines.append(f"Number of tie points: {len(gdf)}")
    print(f"Loaded {len(gdf)} tie points from {tie_points}")

    with rasterio.open(source_raster) as src:
        data = src.read()
        log_lines.append(f"Source dimensions: {src.width} x {src.height} pixels")
        log_lines.append(f"Source bands: {src.count}")
        print(f"Source raster: {src.width} x {src.height} pixels")

        transformer = pyproj.Transformer.from_crs("EPSG:4326", custom_crs, always_xy=True)

        gcps = []
        residuals = []

        log_lines.append("")
        log_lines.append("-" * 80)
        log_lines.append("CONTROL POINTS")
        log_lines.append("-" * 80)
        log_lines.append(
            f"{'ID':<5} {'Pixel X':<10} {'Pixel Y':<10} "
            f"{'Map X':<12} {'Map Y':<12} {'Target X':<12} {'Target Y':<12}"
        )
        log_lines.append("-" * 80)

        for idx, row in gdf.iterrows():
            curr_lon, curr_lat = row.geometry.x, row.geometry.y
            curr_x, curr_y = transformer.transform(curr_lon, curr_lat)

            pix_col, pix_row = ~src.transform * (curr_x, curr_y)

            tgt_lon, tgt_lat = row["lon"], row["lat"]
            tgt_x, tgt_y = transformer.transform(tgt_lon, tgt_lat)

            gcps.append(
                GroundControlPoint(row=pix_row, col=pix_col, x=tgt_x, y=tgt_y, z=0)
            )

            residuals.append({
                'idx': idx,
                'pix_col': pix_col,
                'pix_row': pix_row,
                'curr_x': curr_x,
                'curr_y': curr_y,
                'tgt_x': tgt_x,
                'tgt_y': tgt_y
            })

            log_lines.append(
                f"{idx+1:<5} {pix_col:<10.1f} {pix_row:<10.1f} "
                f"{curr_x:<12.0f} {curr_y:<12.0f} {tgt_x:<12.0f} {tgt_y:<12.0f}"
            )

        new_transform = from_gcps(gcps)

        log_lines.append("")
        log_lines.append("-" * 80)
        log_lines.append("RESIDUAL ANALYSIS")
        log_lines.append("-" * 80)
        log_lines.append(f"{'ID':<5} {'dX (m)':<12} {'dY (m)':<12} {'Residual (m)':<15}")
        log_lines.append("-" * 80)

        residual_errors = []
        dx_list = []
        dy_list = []

        for res in residuals:
            predicted_x, predicted_y = new_transform * (res['pix_col'], res['pix_row'])

            dx = predicted_x - res['tgt_x']
            dy = predicted_y - res['tgt_y']
            residual = np.sqrt(dx**2 + dy**2)

            residual_errors.append(residual)
            dx_list.append(dx)
            dy_list.append(dy)

            log_lines.append(f"{res['idx']+1:<5} {dx:<12.2f} {dy:<12.2f} {residual:<15.2f}")

        residual_errors = np.array(residual_errors)
        dx_array = np.array(dx_list)
        dy_array = np.array(dy_list)

        rmse = np.sqrt(np.mean(residual_errors**2))
        rmse_x = np.sqrt(np.mean(dx_array**2))
        rmse_y = np.sqrt(np.mean(dy_array**2))
        mean_error = np.mean(residual_errors)
        max_error = np.max(residual_errors)
        min_error = np.min(residual_errors)
        std_error = np.std(residual_errors)

        log_lines.append("-" * 80)
        log_lines.append("")
        log_lines.append("TRANSFORMATION STATISTICS")
        log_lines.append("-" * 80)
        log_lines.append(f"Transformation type: Affine (1st-order polynomial, 6 parameters)")
        log_lines.append(f"Number of GCPs used: {len(gcps)}")
        log_lines.append(f"Degrees of freedom:  {max(0, len(gcps) - 3)}")
        log_lines.append("")
        log_lines.append("Residual Errors:")
        log_lines.append(f"  Mean error:     {mean_error:10.2f} m")
        log_lines.append(f"  RMSE (total):   {rmse:10.2f} m")
        log_lines.append(f"  RMSE X:         {rmse_x:10.2f} m")
        log_lines.append(f"  RMSE Y:         {rmse_y:10.2f} m")
        log_lines.append(f"  Std deviation:  {std_error:10.2f} m")
        log_lines.append(f"  Maximum error:  {max_error:10.2f} m")
        log_lines.append(f"  Minimum error:  {min_error:10.2f} m")

        log_lines.append("")
        log_lines.append("Transformation Matrix:")
        log_lines.append(f"  a (scale X):    {new_transform.a:15.6f}")
        log_lines.append(f"  b (rotation):   {new_transform.b:15.6f}")
        log_lines.append(f"  c (translation X): {new_transform.c:15.2f}")
        log_lines.append(f"  d (rotation):   {new_transform.d:15.6f}")
        log_lines.append(f"  e (scale Y):    {new_transform.e:15.6f}")
        log_lines.append(f"  f (translation Y): {new_transform.f:15.2f}")

        pixel_size_x = abs(new_transform.a)
        pixel_size_y = abs(new_transform.e)
        rotation = np.degrees(np.arctan2(new_transform.b, new_transform.a))

        log_lines.append("")
        log_lines.append("Derived Parameters:")
        log_lines.append(f"  Pixel size X:   {pixel_size_x:10.2f} m/pixel")
        log_lines.append(f"  Pixel size Y:   {pixel_size_y:10.2f} m/pixel")
        log_lines.append(f"  Rotation:       {rotation:10.4f} degrees")

        log_lines.append("")
        log_lines.append("QUALITY ASSESSMENT")
        log_lines.append("-" * 80)
        if rmse < 100:
            quality = "EXCELLENT"
        elif rmse < 500:
            quality = "GOOD"
        elif rmse < 1000:
            quality = "ACCEPTABLE"
        else:
            quality = "POOR"
        log_lines.append(f"Overall quality: {quality} (RMSE: {rmse:.2f} m)")

        if len(gcps) < 4:
            log_lines.append("WARNING: Less than 4 GCPs used. Consider adding more points.")

        if max_error > 3 * mean_error:
            log_lines.append(f"WARNING: Point {np.argmax(residual_errors)+1} has unusually high residual.")
            log_lines.append("         Consider checking this control point.")

        log_lines.append("")
        log_lines.append("=" * 80)

        with open(log_file, 'w') as f:
            f.write('\n'.join(log_lines))

        print(f"\nLog file written to: {log_file}")
        print(f"RMSE: {rmse:.2f} m")

        profile = src.profile.copy()
        profile.update(crs=custom_crs, transform=new_transform)

        with rasterio.open(target_raster, "w", **profile) as dst:
            dst.write(data)

    print(f"Georeferenced raster saved to {target_raster}")
    return str(log_file)


# ============================================================================
# SCons BUILDER FOR GEOREFERENCING
# ============================================================================

DEFAULT_CRS = 3031

def georef_builder(target, source, env):
    """
    SCons builder that calls georeference_map.

    target[0]: log file (output)
    target[1]: georeferenced raster in maps/ (output)
    source[0]: GPKG tie points file (input)
    source[1]: ungeoreferenced TIFF in _georeferencing/ (input)
    """
    tie_points = str(source[0])
    source_raster = str(source[1])
    target_log = str(target[0])
    target_raster = str(target[1])

    crs = env.get('TARGET_CRS', DEFAULT_CRS)

    try:
        georeference_map(source_raster, target_raster, tie_points, target_log, target_crs=crs)
        print(f"OK: Georeferenced {Path(source_raster).name}")
        return 0
    except Exception as e:
        print(f"ERROR: Georeferencing {Path(source_raster).name}: {e}")
        return 1


georef_action = Action(georef_builder, "Georeferencing $SOURCE")
georef_builder_obj = Builder(action=georef_action)
env.Append(BUILDERS={'Georef': georef_builder_obj})


# ============================================================================
# FIND AND BUILD TARGETS FROM EXCEL
# ============================================================================

try:
    df = pd.read_excel(atlas_master, dtype={"Target crs": "string"})
    print(f"Loaded {atlas_master} with {len(df)} rows")
except Exception as e:
    print(f"ERROR: Could not load {atlas_master}: {e}")
    df = pd.DataFrame()

if not df.empty and 'tiepoint_path' in df.columns and 'raw_path' in df.columns:

    build_tasks = []

    for idx, row in df.iterrows():
        tiepoint_paths = row['tiepoint_path']
        raw_paths = row['raw_path']

        if (pd.isna(tiepoint_paths) or tiepoint_paths == '-'
                or pd.isna(raw_paths) or raw_paths == '-'):
            continue

        target_crs = get_target_crs(row.get('Target crs', DEFAULT_CRS))

        tiepoint_list = [p.strip() for p in str(tiepoint_paths).split(',')]
        raw_list = [p.strip() for p in str(raw_paths).split(',')]

        if len(tiepoint_list) != len(raw_list):
            print(f"WARNING: Row {idx} has mismatched tiepoint/raw path counts")
            continue

        for tiepoint_path, raw_path in zip(tiepoint_list, raw_list):
            tiepoint_path = Path(tiepoint_path)
            raw_path = Path(raw_path)

            if not tiepoint_path.exists():
                print(f"WARNING: Tiepoint file not found: {tiepoint_path}")
                continue

            if not raw_path.exists():
                print(f"WARNING: Raw raster file not found: {raw_path}")
                continue

            stem = tiepoint_path.stem

            # ---------------------------------------------------------------
            # DIRECTORY RENAMING: use stem name directly (no _georeferencing)
            # The subdirectory for accessory files is named after the map stem
            # and sits alongside the georeferenced TIFF.
            # ---------------------------------------------------------------
            map_dir = tiepoint_path.parent.parent / stem
            os.makedirs(str(map_dir), exist_ok=True)

            target_tiff = tiepoint_path.parent.parent / f"{stem}.tiff"
            target_log = map_dir / f"{stem}.log"

            build_tasks.append({
                'tiepoint': str(tiepoint_path),
                'raw': str(raw_path),
                'target_log': str(target_log),
                'target_tiff': str(target_tiff),
                'map_dir': str(map_dir),
                'stem': stem,
                'target_crs': target_crs,
                'row': row,
            })

    print(f"\nFound {len(build_tasks)} georeferencing tasks from Excel")

    # Register all build targets — deduplicate by target_tiff path to
    # prevent "Two different environments" warnings when the same map
    # appears on multiple Excel rows (e.g. overlapping tiepoint entries).
    registered_targets = set()

    for task in sorted(build_tasks, key=lambda x: x['stem']):

        target_key = task['target_tiff']
        if target_key in registered_targets:
            print(f"INFO: Skipping duplicate target: {task['stem']} (already registered)")
            continue
        registered_targets.add(target_key)

        # --- Georeferencing target ---
        task_env = env.Clone()
        task_env['TARGET_CRS'] = task['target_crs']

        georef_targets = task_env.Georef(
            [task['target_log'], task['target_tiff']],
            [task['tiepoint'], task['raw']]
        )
        env.Depends(georef_targets, atlas_master)

        # --- BibTeX generation target ---
        row = task['row']

        # Determine volume from the raw path (heuristic: 'II' in path -> vol 2)
        volume = 2 if 'II' in task['raw'] else 1

        cite_key, bib_entry = generate_map_bibtex(row, volume=volume)

        bib_path = str(Path(task['map_dir']) / f"{task['stem']}.bib")

        bib_env = env.Clone()
        bib_env['BIB_ENTRY'] = bib_entry

        bib_target = bib_env.BibTeX(
            target=bib_path,
            source=atlas_master
        )

else:
    print("ERROR: Could not find 'tiepoint_path' and/or 'raw_path' columns in Excel file")


# ============================================================================
# MASTER BibTeX FILE: atlas_antarktiki_maps.bib
# ============================================================================
# One entry per spreadsheet row (all row types), plus the parent @book entry.
# Saved to atlas/atlas_antarktiki_maps.bib
# Depends on all individual per-map .bib nodes so it is always consistent.
# ============================================================================

def master_bibtex_builder(target, source, env):
    """
    SCons builder that generates the master atlas_antarktiki_maps.bib.

    target[0]: atlas/atlas_antarktiki_maps.bib
    source[0]: atlas_master.xlsx
    source[1:]: all individual per-map .bib files (dependency chain)
    env: carries MASTER_DF (pre-read DataFrame) to avoid re-reading Excel
    """
    master_path = str(target[0])

    try:
        df_master = pd.read_excel(str(source[0]), dtype={"Target crs": "string"})
    except Exception as e:
        print(f"ERROR: Could not read {source[0]} for master bib: {e}")
        return 1

    entries = []
    for idx, row in df_master.iterrows():
        title = safe_field(row.get('Title', ''))
        if not title:
            continue
        raw_path_str = safe_field(row.get('raw_path', ''))
        volume = 2 if 'II' in raw_path_str else 1
        try:
            _, bib_entry = generate_bibtex_entry(row, volume=volume)
            entries.append(bib_entry)
        except Exception as e:
            print(f"WARNING: Row {idx} skipped in master bib: {e}")

    content = (
        f"% atlas_antarktiki_maps.bib\n"
        f"% Master bibliography — all atlas entries\n"
        f"% Auto-generated by SConstruct — {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n"
        f"% Entries: {len(entries)} (rows with a Title in {atlas_master})\n\n"
        f"{ATLAS_PARENT_BIB}\n"
        + "\n\n".join(entries)
        + "\n"
    )

    os.makedirs(str(Path(master_path).parent), exist_ok=True)
    with open(master_path, 'w', encoding='utf-8') as f:
        f.write(content)

    print(f"OK: Master bib written to {master_path} ({len(entries)} entries)")
    return 0


master_bib_action = Action(master_bibtex_builder, "Generating master BibTeX $TARGET")
master_bib_builder_obj = Builder(action=master_bib_action)
env.Append(BUILDERS={'MasterBibTeX': master_bib_builder_obj})

# Collect all individual bib nodes registered during the georef loop
all_bib_nodes = []
# Re-scan registered map_dirs for their .bib files as SCons nodes
for task in (build_tasks if 'build_tasks' in dir() else []):
    bib_path = str(Path(task['map_dir']) / f"{task['stem']}.bib")
    node = env.File(bib_path)
    if node not in all_bib_nodes:
        all_bib_nodes.append(node)

master_bib_target = Path('atlas') / 'atlas_antarktiki_maps.bib'
os.makedirs('atlas', exist_ok=True)

master_bib_node = env.MasterBibTeX(
    target=str(master_bib_target),
    source=[atlas_master] + all_bib_nodes
)
print(f"Configured master bib: {master_bib_target} (depends on {len(all_bib_nodes)} individual bib files)")

print("\n" + "=" * 80)
